# PostgreSQL — Neon: "Pooled" para runtime; "Direct" para migraciones (obligatorio con Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth — https://next-auth.js.org/configuration/options
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# API de Gemini (ruta /api/scrape)
GEMINI_API_KEY=""
